{erl_opts, [debug_info]}.

{deps, []}.

{relx, [
    {release, {quarter, "0.1.0"}, [quarter]},
    {dev_mode, false},
    %% Devuan-kehityskone ja OpenBSD/RPI4-tuotantokone ovat eri käyttöjärjestelmiä
    %% ja arkkitehtuureja. Älä pakkaa Linuxin ERTS:iä OpenBSD:lle vietävään
    %% releaseen; asenna Erlang tuotantokoneelle tai rakenna release OpenBSD:ssä.
    {include_erts, false},
    {extended_start_script, true},
    {sys_config, "config/sys.config"},
    {vm_args, "config/vm.args"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {release, {quarter, "0.1.0"}, [quarter]},
            {dev_mode, false},
            {include_erts, false},
            {extended_start_script, true},
            {sys_config, "config/sys.config"},
            {vm_args, "config/vm.args"}
        ]}
    ]}
]}.
